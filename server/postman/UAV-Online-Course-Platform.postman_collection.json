              }
            }
          ]
        },
        {
          "name": "POST /courses (Admin) - create course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"UAV Fundamentals\",\n  \"description\": \"Learn UAV basics and flight safety.\",\n  \"category\": \"Aviation\",\n  \"instructor\": \"Dr. Sky\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses",
              "host": ["{{baseUrl}}"],
              "path": ["courses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('course id returned', function () {",
                  "  pm.expect(json.course).to.have.property('_id');",
                  "});",
                  "pm.environment.set('courseId', json.course._id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PUT /courses/:id (Admin) - update course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Learn UAV basics, safety, and regulations.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "{{courseId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Updated description present', function () {",
                  "  pm.expect(json.course).to.have.property('description');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
